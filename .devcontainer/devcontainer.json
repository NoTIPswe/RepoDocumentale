{
    "name": "RepoDocumentale",
    "image": "ghcr.io/notipswe/notip-docs-dev:v0.0.1",
    "postCreateCommand": "python3 -m venv .venv && ./.venv/bin/python -m pip install --upgrade pip && ./.venv/bin/pip install -r notipdo/requirements.txt && ./.venv/bin/pip install -e notipdo/",
    "remoteEnv": {
        "PATH": "${containerWorkspaceFolder}/.venv/bin:${containerEnv:PATH}",
        "LANG": "C.UTF-8",
        "LC_ALL": "C.UTF-8",
        "PYTHONUTF8": "1"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "nvarner.typst-lsp",
                "myriad-dreamin.tinymist",
                "tomoki1207.pdf"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
            }
        }
    },
    "updateRemoteUserUID": true,
    "remoteUser": "dev",
    "workspaceFolder": "/workspaces/RepoDocumentale"
}