@startuml
title NOTIP Management API - Architecture (1/3)

skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam defaultFontColor #000000
skinparam nodesep 8
skinparam ranksep 8
skinparam linetype ortho
skinparam packageStyle rectangle

package "NOTIP Management API" <<Rectangle>> {
  class "AppModule" as AppModule {
    +imports: ConfigModule, EventEmitterModule, MetricsModule, TypeOrmModule
    +imports: AuthModule, AdminModule, GatewaysModule, AlertsModule
    +imports: ThresholdsModule, AuditLogModule, ApiClientModule, CostsModule
    +imports: KeysModule, UsersModule, CommandModule
  }

  class "AppController" as AppController {
    +getHello(): string
    +getHealth(): {status}
  }

  class "AppService" as AppService {
    +getHello(): string
  }

  class "TenantEntity" as TenantEntity {
    +id: string
    +name: string
    +status: TenantStatus
    +suspensionIntervalDays: number
    +suspensionUntil: Date
    +createdAt: Date
    +updatedAt: Date
    +users: UserEntity[]
    +gateways: GatewayEntity[]
  }

  class "EnvValidation" as EnvValidation {
    +validate(config): AppConfig
  }

  class "MetricsInterceptor" as MetricsInterceptor
  class "LastAccessInterceptor" as LastAccessInterceptor
  class "AuditInterceptor" as AuditInterceptor

  package "Auth Module" as AuthModule {
    class "JwtStrategy" as JwtStrategy
    class "AuthController" as AuthController
    class "ImpersonationService" as ImpersonationService
    class "JwtAuthGuard" as JwtAuthGuard
    class "RolesGuard" as RolesGuard
    class "AccessPolicyGuard" as AccessPolicyGuard
    class "BlockImpersonationGuard" as BlockImpersonationGuard
  }

  package "Admin Module" as AdminModule {
    class "TenantsController" as TenantsController
    class "TenantsService" as TenantsService
    class "TenantsPersistenceService" as TenantsPersistenceService
    class "KeycloakAdminService" as KeycloakAdminService
    class "AdminGatewaysController" as AdminGatewaysController
    class "AdminGatewaysService" as AdminGatewaysService
    class "AdminGatewaysPersistenceService" as AdminGatewaysPersistenceService
  }

  package "Metrics Module" as MetricsModule {
    class "MetricsController" as MetricsController
    class "MetricsService" as MetricsService
  }

  ' Core relationships
  AppController --> AppService
  AppModule --> AppController
  AppModule --> AppService
  AppModule --> MetricsInterceptor
  AppModule --> LastAccessInterceptor
  AppModule --> AuditInterceptor
  MetricsInterceptor --> MetricsService
  LastAccessInterceptor ..> UserEntity
  AuditInterceptor --> AuditLogService

  ' Auth relationships
  AppModule --> AuthModule
  AuthModule --> JwtStrategy
  AuthModule --> JwtAuthGuard
  AuthModule --> RolesGuard
  AuthModule --> AccessPolicyGuard
  AuthModule --> BlockImpersonationGuard
  BlockImpersonationGuard --> AuditLogService
  AccessPolicyGuard ..> TenantEntity

  ' Admin relationships
  AppModule --> AdminModule
  AdminModule --> TenantsController
  TenantsController --> TenantsService
  TenantsService --> TenantsPersistenceService
  TenantsService --> KeycloakAdminService
  TenantsPersistenceService --> TenantEntity
  TenantsPersistenceService --> UserEntity
  AdminModule --> AdminGatewaysController
  AdminGatewaysController --> AdminGatewaysService
  AdminGatewaysService --> AdminGatewaysPersistenceService

  ' Metrics relationships
  AppModule --> MetricsModule
  MetricsModule --> MetricsController
  MetricsModule --> MetricsService
  MetricsController --> MetricsService
}

note top of AppModule
  Main application module
  Orchestrates all feature modules
  Configures global interceptors
  Sets up TypeORM database connection
end note

note top of TenantEntity
  Core entity shared across modules
  ManyToOne/OneToMany relationships
  with Users, Gateways, Alerts, etc.
end note

note top of AuthModule
  Handles JWT authentication
  Role-based access control
  Tenant suspension checks
  User impersonation support
end note

@enduml
