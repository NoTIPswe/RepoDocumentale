@startuml
title Alerts Module - Class Diagram

skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam defaultFontColor #000000
skinparam class {
  BackgroundColor #E8F4FD
  BorderColor #2196F3
  ArrowColor #1976D2
}
skinparam enum {
  BackgroundColor #FFF3E0
  BorderColor #FF9800
}
skinparam interface {
  BackgroundColor #E8F4FD
  BorderColor #2196F3
}

skinparam linetype ortho
skinparam packageStyle rectangle

package "alerts" <<Rectangle>> {
  class "AlertsController" as AlertsController {
    -as: AlertsService
    +getAlerts(tenantId, from?, to?, gatewayId?): AlertsResponseDto[]
    +getAlertsConfig(tenantId): AlertsConfigResponseDto
    +setDefaultAlertsConfig(tenantId, dto): SetAlertsConfigDefaultResponseDto
    +setGatewayAlertsConfig(tenantId, gatewayId, dto): SetGatewayAlertsConfigResponseDto
    +deleteGatewayAlertsConfig(tenantId, gatewayId): void
  }

  class "AlertsService" as AlertsService {
    -aps: AlertsPersistenceService
    -gatewayService: GatewaysService
    +setGatewayAlertsConfig(input): AlertsConfigEntity
    +deleteGatewayAlertsConfig(tenantId, gatewayId): void
    +setDefaultAlertsConfig(input): AlertsConfigEntity
    +getAlertsConfig(input): AlertsConfigModel
    +getAlerts(input): AlertsModel[]
  }

  class "AlertsPersistenceService" as AlertsPersistenceService {
    -r: Repository<AlertsEntity>
    -rac: Repository<AlertsConfigEntity>
    +setGatewayAlertsConfig(input): AlertsConfigEntity
    +deleteGatewayAlertsConfig(tenantId, gatewayId): boolean
    +setDefaultAlertsConfig(input): AlertsConfigEntity
    +getAlertsConfig(tenantId): AlertsConfigEntity[]
    +findAllAlertConfigs(): AlertsConfigEntity[]
    +getAlerts(input): AlertsEntity[]
    +countAlerts(tenantId): number
    +saveAlert(alert): AlertsEntity
  }

  class "AlertConfigNatsResponderService" as AlertConfigNatsResponderService {
    -alertsPersistenceService: AlertsPersistenceService
    -logger: Logger
    -codec: JSONCodec
    -connection: NatsConnection
    -subscription: Subscription
    +onModuleInit(): void
    +onModuleDestroy(): void
    -consumeRequests(subscription): void
    -resolveServers(): string[]
    -buildConnectionOptions(servers): ConnectionOptions
    -applyTlsOptions(options): boolean
  }

  class "AlertsNatsService" as AlertsNatsService {
    -nats: JetStreamClient
    -persistence: AlertsPersistenceService
    -logger: Logger
    +onModuleInit(): void
  }

  class "AlertsMapper" as AlertsMapper {
    {static} toAlertsModel(entity): AlertsModel
    {static} toAlertsConfigModel(entities[]): AlertsConfigModel
    {static} toAlertsResponseDto(model): AlertsResponseDto
    {static} toSetAlertsConfigDefaultResponseDto(entity): SetAlertsConfigDefaultResponseDto
    {static} toSetGatewayAlertsConfigResponseDto(entity): SetGatewayAlertsConfigResponseDto
    {static} toAlertsConfigResponseDto(model): AlertsConfigResponseDto
    -toIsoDateString(value, fallback): string
  }

  class "SetGatewayAlertsConfigRequestDto" as SetGatewayAlertsConfigRequestDto {
    +gatewayUnreachableTimeoutMs: number
  }

  class "SetGatewayAlertsConfigResponseDto" as SetGatewayAlertsConfigResponseDto {
    +gatewayId: string
    +timeoutMs: number
    +updatedAt: string
  }

  class "SetAlertsConfigDefaultRequestDto" as SetAlertsConfigDefaultRequestDto {
    +tenantUnreachableTimeoutMs: number
  }

  class "SetAlertsConfigDefaultResponseDto" as SetAlertsConfigDefaultResponseDto {
    +tenantId: string
    +defaultTimeoutMs: number
    +defaultUpdatedAt: string
  }

  class "AlertsResponseDto" as AlertsResponseDto {
    +id: string
    +gatewayId: string
    +type: AlertType
    +details: AlertsDetailsDto
    +createdAt: string
  }

  class "AlertsDetailsDto" as AlertsDetailsDto {
    +lastSeen: string
    +timeoutConfigured: number
  }

  class "AlertsConfigResponseDto" as AlertsConfigResponseDto {
    +defaultTimeoutMs: number
    +defaultUpdatedAt?: string
    +gatewayOverrides: AlertsGatewayOverridesResponseDto[]
  }

  class "AlertsGatewayOverridesResponseDto" as AlertsGatewayOverridesResponseDto {
    +gatewayId: string
    +timeoutMs: number
    +updatedAt?: string
  }

  class "AlertsModel" as AlertsModel {
    +id: string
    +tenantId: string
    +type: AlertType
    +details: AlertsDetails
    +gatewayId: string
    +createdAt: Date
  }

  class "AlertsConfigModel" as AlertsConfigModel {
    +defaultTimeoutMs: number
    +defaultUpdatedAt?: Date
    +gatewayOverrides: { gatewayId, gatewayTimeoutMs, updatedAt? }[]
  }

  class "AlertsEntity" as AlertsEntity {
    +id: string
    +tenantId: string
    +type: AlertType
    +gatewayId: string
    +details: Record<string, unknown> & AlertsDetails
    +createdAt: Date
  }

  class "AlertsConfigEntity" as AlertsConfigEntity {
    +id: string
    +tenantId: string
    +gatewayId: string | null
    +gatewayTimeoutMs: number
    +updatedAt: Date
  }

  interface "AlertsDetails" as AlertsDetails {
    +lastSeen: Date
    +timeoutConfigured: number
  }

  interface "GetAlertsConfigInput" as GetAlertsConfigInput {
    +tenantId: string
  }

  interface "GetAlertsInput" as GetAlertsInput {
    +tenantId: string
    +from?: string
    +to?: string
    +gatewayId?: string
  }

  interface "SetAlertsConfigDefaultInput" as SetAlertsConfigDefaultInput {
    +tenantId: string
    +defaultTimeoutMs: number
  }

  interface "SetGatewayAlertsConfigInput" as SetGatewayAlertsConfigInput {
    +tenantId: string
    +gatewayId: string
    +gatewayTimeoutMs: number
  }

  interface "GetAlertsPersistenceInput" as GetAlertsPersistenceInput {
    +tenantId: string
    +from?: string
    +to?: string
    +gatewayId?: string
  }

  interface "SetAlertsConfigDefaultPersistenceInput" as SetAlertsConfigDefaultPersistenceInput {
    +tenantId: string
    +defaultTimeoutMs: number
  }

  interface "SetGatewayAlertsConfigPersistenceInput" as SetGatewayAlertsConfigPersistenceInput {
    +tenantId: string
    +gatewayId: string
    +gatewayTimeoutMs: number
  }

  enum "AlertType" as AlertType {
    GATEWAY_OFFLINE
  }

  class "TenantEntity" as TenantEntity
  class "GatewayEntity" as GatewayEntity
  class "GatewaysService" as GatewaysService
  class "JetStreamClient" as JetStreamClient

  AlertsController --> AlertsService : uses
  AlertsController --> AlertsMapper : maps to DTO
  AlertsController ..> SetAlertsConfigDefaultRequestDto
  AlertsController ..> SetAlertsConfigDefaultResponseDto
  AlertsController ..> SetGatewayAlertsConfigRequestDto
  AlertsController ..> SetGatewayAlertsConfigResponseDto
  AlertsController ..> AlertsResponseDto
  AlertsController ..> AlertsConfigResponseDto
  AlertsController ..> GetAlertsInput
  AlertsController ..> GetAlertsConfigInput
  AlertsController ..> SetAlertsConfigDefaultInput
  AlertsController ..> SetGatewayAlertsConfigInput

  AlertsService --> AlertsPersistenceService : uses
  AlertsService --> GatewaysService : uses
  AlertsService --> AlertsModel : returns
  AlertsService --> AlertsConfigModel : returns
  AlertsService ..> GetAlertsInput : receives
  AlertsService ..> GetAlertsConfigInput : receives
  AlertsService ..> SetAlertsConfigDefaultInput : receives
  AlertsService ..> SetGatewayAlertsConfigInput : receives
  AlertsService ..> GetAlertsPersistenceInput : builds
  AlertsService ..> SetAlertsConfigDefaultPersistenceInput : builds
  AlertsService ..> SetGatewayAlertsConfigPersistenceInput : builds

  AlertsPersistenceService --> AlertsEntity
  AlertsPersistenceService --> AlertsConfigEntity
  AlertsPersistenceService ..> GetAlertsPersistenceInput
  AlertsPersistenceService ..> SetAlertsConfigDefaultPersistenceInput
  AlertsPersistenceService ..> SetGatewayAlertsConfigPersistenceInput

  AlertConfigNatsResponderService --> AlertsPersistenceService : reads configs
  AlertsNatsService --> AlertsPersistenceService : persists/reads
  AlertsNatsService --> JetStreamClient : uses

  AlertsMapper --> AlertsEntity : from
  AlertsMapper --> AlertsConfigEntity : from
  AlertsMapper --> AlertsModel : to
  AlertsMapper --> AlertsConfigModel : to
  AlertsMapper --> AlertsResponseDto : to
  AlertsMapper --> AlertsConfigResponseDto : to
  AlertsMapper --> SetAlertsConfigDefaultResponseDto : to
  AlertsMapper --> SetGatewayAlertsConfigResponseDto : to

  AlertsConfigEntity --> TenantEntity : ManyToOne
  AlertsConfigEntity --> GatewayEntity : ManyToOne

  AlertsModel --> AlertType
  AlertsEntity --> AlertType
  AlertsResponseDto --> AlertType
}

note top of AlertsController
  @Controller('alerts')
  @TenantScoped()
  Endpoints: GET alerts, GET config, PUT default config,
  PUT gateway config, DELETE gateway config
end note

note top of AlertsService
  Business logic layer
  - Validates gateway ownership
  - Maps alert entities to models
  - Translates service input to persistence input
end note

note top of AlertsPersistenceService
  Data access layer
  - Upserts config on [tenantId, gatewayId]
  - Handles default config deduplication
  - Time-range queries with Between/MoreThanOrEqual/LessThanOrEqual
end note

note top of AlertConfigNatsResponderService
  Direct NATS responder
  - Conditional on MOCK_NATS env
  - Full TLS/mTLS support
  - Responds to config list requests
end note

note top of AlertsNatsService
  Internal NATS integration
  - Core NATS request-reply for config listing
  - JetStream subscription for gateway offline alerts
  - Persists GATEWAY_OFFLINE alerts
end note

@enduml
