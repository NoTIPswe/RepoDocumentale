@startuml
title Command Module - Class Diagram

skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam defaultFontColor #000000
skinparam class {
  BackgroundColor #E8F4FD
  BorderColor #2196F3
  ArrowColor #1976D2
}
skinparam enum {
  BackgroundColor #FFF3E0
  BorderColor #FF9800
}
skinparam interface {
  BackgroundColor #E8F4FD
  BorderColor #2196F3
}
skinparam linetype ortho
skinparam packageStyle rectangle

package "command" <<Rectangle>> {
  class "CommandController" as CommandController {
    -cs: CommandService
    +sendConfig(tenantId, gatewayId, dto): CommandResponseDto
    +sendFirmware(tenantId, gatewayId, dto): CommandResponseDto
    +getStatus(tenantId, gatewayId, commandId): CommandStatusResponseDto
  }

  class "CommandService" as CommandService {
    -cps: CommandPersistenceService
    -gatewaysService: GatewaysService
    -jetStreamClient: JetStreamClient
    -logger: Logger
    +sendConfig(input): CommandModel
    +sendFirmware(input): CommandModel
    +getStatus(input): CommandModel
    -publishToNats(model, type, payload): void
    -ensureGatewayOwnership(tenantId, gatewayId): void
  }

  class "CommandPersistenceService" as CommandPersistenceService {
    -r: Repository<CommandEntity>
    +queueCommand(input): CommandEntity
    +findCommand(input): CommandEntity
    +countCommands(tenantId): number
  }

  class "CommandWritingPersistenceService" as CommandWritingPersistenceService {
    -r: Repository<CommandEntity>
    -gatewaysRepository: Repository<GatewayEntity>
    +updateStatus(input): CommandEntity
    +applyAckedCommandEffects(command): void
    -mapCommandGatewayStatus(status): GatewayStatus
  }

  class "CommandsAckConsumer" as CommandsAckConsumer {
    -jetStreamClient: JetStreamClient
    -writingPersistence: CommandWritingPersistenceService
    -logger: Logger
    +onModuleInit(): void
    -processMessage(message): void
    -parsePayload(buffer): CommandAckPayload
    -resolveCommandId(payload): string
    -normalizeStatus(value): CommandStatus
  }

  class "CommandMapper" as CommandMapper {
    {static} toModel(entity): CommandModel
    {static} toCommandResponseDto(model): CommandResponseDto
    {static} toCommandStatusResponseDto(model): CommandStatusResponseDto
  }

  class "SendConfigRequestDto" as SendConfigRequestDto {
    +sendFrequencyMs?: number
    +status?: string
  }

  class "SendFirmwareRequestDto" as SendFirmwareRequestDto {
    +firmwareVersion: string
    +downloadUrl: string
  }

  class "CommandResponseDto" as CommandResponseDto {
    +commandId: string
    +status: CommandStatus
    +issuedAt: string
  }

  class "CommandStatusResponseDto" as CommandStatusResponseDto {
    +commandId: string
    +status: CommandStatus
    +timestamp: string
  }

  class "CommandModel" as CommandModel {
    +id: string
    +tenantId: string
    +gatewayId: string
    +type: CommandType
    +status: CommandStatus
    +issuedAt: Date
    +ackReceivedAt: Date
    +createdAt: Date
  }

  class "CommandEntity" as CommandEntity {
    +id: string
    +gatewayId: string
    +gateway: GatewayEntity
    +tenantId: string
    +tenant: TenantEntity
    +type: CommandType
    +status: CommandStatus
    +issuedAt: Date
    +ackReceivedAt: Date
    +requestedSendFrequencyMs: number
    +requestedStatus: string
    +requestedFirmwareVersion: string
    +createdAt: Date
  }

  enum "CommandType" as CommandType {
    CONFIG
    FIRMWARE
    SUSPEND
  }

  enum "CommandStatus" as CommandStatus {
    QUEUED
    ACK
    NACK
    EXPIRED
    TIMEOUT
  }

  interface "SendConfigCommandInput" as SendConfigCommandInput {
    +tenantId: string
    +gatewayId: string
    +sendFrequencyMs?: number
    +status?: string
  }

  interface "SendFirmwareCommandInput" as SendFirmwareCommandInput {
    +tenantId: string
    +gatewayId: string
    +firmwareVersion: string
    +downloadUrl: string
  }

  interface "GetCommandStatusInput" as GetCommandStatusInput {
    +tenantId: string
    +gatewayId: string
    +commandId: string
  }

  interface "CommandAckPayload" as CommandAckPayload {
    +command_id?: string
    +commandId?: string
    +status: CommandStatus
    +timestamp: string
  }

  class "GatewayEntity" as GatewayEntity
  class "TenantEntity" as TenantEntity
  class "GatewaysService" as GatewaysService

  CommandController --> CommandService : uses
  CommandController --> CommandMapper : maps to DTO

  CommandService --> CommandPersistenceService : uses
  CommandService --> GatewaysService : validates ownership
  CommandService --> JetStreamClient : publishes commands
  CommandService --> CommandModel : returns

  CommandPersistenceService --> CommandEntity : CRUD

  CommandWritingPersistenceService --> CommandEntity : updates status
  CommandWritingPersistenceService --> GatewayEntity : updates effects

  CommandsAckConsumer --> JetStreamClient : subscribes to acks
  CommandsAckConsumer --> CommandWritingPersistenceService : updates status

  CommandMapper --> CommandEntity : from
  CommandMapper --> CommandModel : to
  CommandMapper --> CommandResponseDto : to
  CommandMapper --> CommandStatusResponseDto : to

  CommandEntity --> GatewayEntity : ManyToOne
  CommandEntity --> TenantEntity : ManyToOne

  CommandModel --> CommandType
  CommandModel --> CommandStatus
  CommandEntity --> CommandType
  CommandEntity --> CommandStatus
}

note top of CommandController
  @Controller('cmd')
  @TenantScoped()
  Endpoints:
  - POST :gatewayId/config
  - POST :gatewayId/firmware
  - GET :gatewayId/status/:commandId
end note

note top of CommandService
  Business logic layer
  - Validates gateway ownership
  - Queues commands in DB
  - Publishes to NATS subject:
    command.gw.{tenantId}.{gatewayId}
end note

note top of CommandWritingPersistenceService
  Write-oriented persistence
  - Updates command status on ACK
  - Applies side effects to gateway:
    * Updates metadata.sendFrequencyMs
    * Updates metadata.status
    * Updates firmwareVersion
end note

note top of CommandsAckConsumer
  JetStream consumer
  - Subject: command.ack.>
  - Normalizes status values
  - Updates command in DB
  - Triggers gateway effects on ACK
end note

@enduml
