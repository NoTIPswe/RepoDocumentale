@startuml
title Gateways Module - Class Diagram

skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam defaultFontColor #000000
skinparam class {
  BackgroundColor #E8F4FD
  BorderColor #2196F3
  ArrowColor #1976D2
}
skinparam enum {
  BackgroundColor #FFF3E0
  BorderColor #FF9800
}
skinparam interface {
  BackgroundColor #E8F4FD
  BorderColor #2196F3
}
skinparam linetype ortho
skinparam packageStyle rectangle

package "gateways" <<Rectangle>> {
  class "GatewaysController" as GatewaysController {
    -gs: GatewaysService
    +getGateways(tenantId, req): GatewayResponseDto[]
    +getGatewayById(tenantId, gatewayId, req): GatewayResponseDto
    +updateGateway(tenantId, gatewayId, dto): UpdateGatewayResponseDto
    +deleteGateway(tenantId, gatewayId): void
  }

  class "GatewaysService" as GatewaysService {
    -gps: GatewaysPersistenceService
    -eventEmitter: EventEmitter2
    -logger: Logger
    +getAlertsForGateway(gatewayId): []
    +getGateways(input): GatewayModel[]
    +findById(input): GatewayModel
    +findByIdUnscoped(gatewayId): GatewayModel | null
    +findByFactoryId(factoryId): GatewayModel | null
    +updateGateway(input): GatewayModel
    +deleteGateway(input): void
    +updateGatewayRuntimeStatus(gatewayId, status, lastSeenAt): boolean
  }

  class "GatewaysPersistenceService" as GatewaysPersistenceService {
    -r: Repository<GatewayEntity>
    -metadataRepo: Repository<GatewayMetadataEntity>
    +getGateways(input): GatewayEntity[]
    +findById(input): GatewayEntity | null
    +findByIdUnscoped(gatewayId): GatewayEntity | null
    +findByFactoryId(factoryId): GatewayEntity | null
    +updateGatewayRuntimeStatus(input): GatewayEntity | null
    +updateGateway(input): GatewayEntity | null
    +deleteGateway(input): GatewayEntity | null
  }

  class "GatewayStatusNatsResponderService" as GatewayStatusNatsResponderService {
    -gatewaysService: GatewaysService
    -logger: Logger
    -codec: JSONCodec
    -connection: NatsConnection
    -subscriptions: Subscription[]
    +onModuleInit(): void
    +onModuleDestroy(): void
    -consumeRequests(subscription, handler): void
    -handleUpdate(msg): GatewayStatusUpdateResponse
    -handleGetStatus(msg): GatewayGetStatusResponse
    -decodeRecord(msg): Record | null
    -readNonEmptyString(value, key): string | null
    -normalizeStatus(value): GatewayStatus | null
    -toLifecycleState(status): 'online' | 'offline' | 'paused' | 'provisioning'
    -parseTimestamp(value): Date | null
    -isNonEmptyString(value): boolean
    -resolveServers(): string[]
    -buildConnectionOptions(servers): ConnectionOptions
    -applyTlsOptions(options): boolean
  }

  class "GatewaysNatsService" as GatewaysNatsService {
    -nats: JetStreamClient
    -persistence: GatewaysPersistenceService
    -logger: Logger
    +onModuleInit(): void
    -toLifecycleState(status): string
  }

  class "GatewaysListener" as GatewaysListener {
    -nats: JetStreamClient
    -logger: Logger
    +handleGatewayDecommissioned(payload): void
  }

  class "GatewaysMapper" as GatewaysMapper {
    {static} toModel(entity): GatewayModel
    {static} toResponseDto(model): GatewayResponseDto
    {static} toUpdateResponseDto(model): UpdateGatewayResponseDto
  }

  class "GatewayResponseDto" as GatewayResponseDto {
    +id: string
    +name: string
    +status: GatewayStatus
    +lastSeenAt: string | null
    +provisioned: boolean
    +firmwareVersion?: string
    +sendFrequencyMs: number
  }

  class "UpdateGatewayRequestDto" as UpdateGatewayRequestDto {
    +name: string
  }

  class "UpdateGatewayResponseDto" as UpdateGatewayResponseDto {
    +id: string
    +name: string
    +status: GatewayStatus
    +updatedAt: string
  }

  class "GatewayModel" as GatewayModel {
    +id: string
    +name: string
    +status: GatewayStatus
    +lastSeenAt: Date | null
    +sendFrequencyMs: number
    +factoryKey: string
    +factoryId: string
    +createdAt: Date
    +firmwareVersion: string
    +model: string
    +tenantId: string
    +provisioned: boolean
    +updatedAt?: Date
  }

  class "GatewayEntity" as GatewayEntity {
    +id: string
    +tenantId: string
    +tenant: TenantEntity
    +factoryId: string
    +factoryKeyHash: string | null
    +provisioned: boolean
    +model: string
    +firmwareVersion: string
    +createdAt: Date
    +updatedAt: Date
    +metadata: GatewayMetadataEntity
  }

  class "GatewayMetadataEntity" as GatewayMetadataEntity {
    +gatewayId: string
    +name: string | null
    +status: GatewayStatus
    +lastSeenAt: Date | null
    +sendFrequencyMs: number
    +gateway: GatewayEntity
  }

  enum "GatewayStatus" as GatewayStatus {
    GATEWAY_ONLINE
    GATEWAY_OFFLINE
    GATEWAY_SUSPENDED
    GATEWAYS_PROVISIONING
  }

  class "DEFAULT_GATEWAY_SEND_FREQUENCY_MS" as DefaultFreq {
    {static} value: 30000
  }

  interface "GetGatewaysInput" as GetGatewaysInput {
    +tenantId: string
  }

  interface "GetGatewayByIdInput" as GetGatewayByIdInput {
    +tenantId: string
    +gatewayId: string
  }

  interface "UpdateGatewayInput" as UpdateGatewayInput {
    +tenantId: string
    +gatewayId: string
    +name?: string
  }

  interface "DeleteGatewayInput" as DeleteGatewayInput {
    +tenantId: string
    +gatewayId: string
  }

  interface "GetGatewaysPersistenceInput" as GetGatewaysPersistenceInput {
    +tenantId: string
  }

  interface "GetGatewayByIdPersistenceInput" as GetGatewayByIdPersistenceInput {
    +tenantId: string
    +gatewayId: string
  }

  interface "UpdateGatewayPersistenceInput" as UpdateGatewayPersistenceInput {
    +tenantId: string
    +gatewayId: string
    +name?: string
  }

  interface "DeleteGatewayPersistenceInput" as DeleteGatewayPersistenceInput {
    +tenantId: string
    +gatewayId: string
  }

  class "TenantEntity" as TenantEntity
  class "EventEmitter2" as EventEmitter2
  class "JetStreamClient" as JetStreamClient

  GatewaysController --> GatewaysService : uses
  GatewaysController --> GatewaysMapper : maps to DTO
  GatewaysController ..> GetGatewaysInput
  GatewaysController ..> GetGatewayByIdInput
  GatewaysController ..> UpdateGatewayInput
  GatewaysController ..> DeleteGatewayInput
  GatewaysController ..> GatewayResponseDto
  GatewaysController ..> UpdateGatewayResponseDto

  GatewaysService --> GatewaysPersistenceService : uses
  GatewaysService --> GatewayModel : returns
  GatewaysService --> EventEmitter2 : emits events
  GatewaysService ..> GetGatewaysInput : receives
  GatewaysService ..> GetGatewayByIdInput : receives
  GatewaysService ..> UpdateGatewayInput : receives
  GatewaysService ..> DeleteGatewayInput : receives
  GatewaysService ..> GetGatewaysPersistenceInput : builds
  GatewaysService ..> GetGatewayByIdPersistenceInput : builds
  GatewaysService ..> UpdateGatewayPersistenceInput : builds
  GatewaysService ..> DeleteGatewayPersistenceInput : builds

  GatewaysPersistenceService --> GatewayEntity : CRUD
  GatewaysPersistenceService --> GatewayMetadataEntity : CRUD
  GatewaysPersistenceService --> DefaultFreq : uses constant
  GatewaysPersistenceService ..> GetGatewaysPersistenceInput
  GatewaysPersistenceService ..> GetGatewayByIdPersistenceInput
  GatewaysPersistenceService ..> UpdateGatewayPersistenceInput
  GatewaysPersistenceService ..> DeleteGatewayPersistenceInput

  GatewayStatusNatsResponderService --> GatewaysService : updates status / reads status
  GatewaysNatsService --> JetStreamClient : subscribes core subjects
  GatewaysNatsService --> GatewaysPersistenceService : updates / validates / reads
  GatewaysListener --> JetStreamClient : publishes decommission event

  GatewaysMapper --> GatewayEntity : from
  GatewaysMapper --> GatewayModel : to
  GatewaysMapper --> GatewayResponseDto : to
  GatewaysMapper --> UpdateGatewayResponseDto : to

  GatewayEntity --> TenantEntity : ManyToOne (CASCADE)
  GatewayEntity --> GatewayMetadataEntity : OneToOne (cascade)
  GatewayMetadataEntity --> GatewayStatus : enum
  GatewayModel --> GatewayStatus
  GatewayResponseDto --> GatewayStatus
  UpdateGatewayResponseDto --> GatewayStatus
}

note top of GatewaysController
  @Controller('gateways')
  @TenantScoped()
  Endpoints:
  - GET / (list with obfuscation)
  - GET /:id (with obfuscation)
  - PATCH /:id (block impersonation)
  - DELETE /:id (block impersonation, emit event)
end note

note top of GatewaysService
  Business logic layer
  - Tenant-scoped gateway operations
  - Emits 'gateway.decommissioned' on delete
  - Runtime status updates
  - Factory ID lookups
end note

note top of GatewaysPersistenceService
  Data access layer
  - Filters by tenantId
  - Joins with metadata relation
  - Auto-creates metadata if missing
  - factoryKeyHash is excluded by default unless explicitly selected
end note

note top of GatewayStatusNatsResponderService
  Direct NATS responder
  - Conditional on MOCK_NATS env
  - Full TLS/mTLS support
  - Handles:
    * internal.mgmt.gateway.update-status
    * internal.mgmt.gateway.get-status
  - Normalizes status strings
end note

note top of GatewaysNatsService
  Internal Core NATS listeners
  - internal.mgmt.gateway.update-status
  - internal.mgmt.factory.validate
  - internal.mgmt.gateway.get-status
  - Validates factory credentials with bcrypt
end note

note top of GatewaysListener
  Event listener
  - @OnEvent('gateway.decommissioned')
  - Publishes to NATS:
    gateway.decommissioned.{tenantId}.{gatewayId}
  - Payload contains gatewayId and timestamp
end note

@enduml
