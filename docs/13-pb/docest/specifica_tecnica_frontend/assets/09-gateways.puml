@startuml
title NoTIP Frontend - Gateway Feature Architecture

skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam defaultFontColor #000000
skinparam nodesep 8
skinparam ranksep 8
skinparam linetype ortho
skinparam classAttributeIconSize 0
left to right direction


package "Shared Components" <<Rectangle>> {
  class "DeleteConfirmModalComponent" as DeleteModal {
    --
    -open: input<boolean>
    -title: input<string>
    -message: input<string>
    -busy: input<boolean>
    --
    +onConfirm(): void
    +onCancel(): void
  }
  
  class "ModalLayerComponent" as ModalLayer
  class "StatusBadgeComponent" as StatusBadge
}

package "Core & Other Features" <<Rectangle>> {
  class "AuthService" as AuthSvc
  class "SensorService" as SensorSvc
  class "ObfuscatedMeasureService" as ObfMeasureSvc
  class "ValidatedMeasureFacadeService" as ValMeasureSvc
  class "TelemetryTableComponent" as TelemetryTable
}

package "Gateway Feature" <<Rectangle>> {
  class "GatewayListPageComponent" as GatewayListPage {
    --
    -gateways: Signal<Gateway[]>
    -isLoading: Signal<boolean>
    -selectedGatewayId: Signal<string | null>
    -errorMessage: Signal<string | null>
    --
    +ngOnInit(): void
    +onGatewaySelected(gatewayId: string): void
    -loadGateways(): void
  }

  class "GatewayDetailPageComponent" as GatewayDetailPage {
    --
    -gateway: Signal<Gateway | null>
    -sensors: Signal<Sensor[]>
    -telemetry: Signal<Array<CheckedEnvelope | ObfuscatedEnvelope>>
    -canManage: boolean
    -isBusy: Signal<boolean>
    --
    +ngOnInit(): void
    +ngOnDestroy(): void
    +submitRename(nextNameRaw: string): void
    +submitConfigCommand(config: GatewayConfig): void
    +submitFirmwareCommand(firmware: GatewayFirmware): void
    +confirmDeleteGateway(): void
  }

  class "GatewayCardComponent" as GatewayCard {
    --
    -gateway: input<Gateway>
    -selected: input<boolean>
    -canOpenDetail: input<boolean>
    --
    +onOpenDetail(): void
  }

  class "GatewayActionsComponent" as GatewayActions {
    --
    -canManage: input<boolean>
    -showRename: input<boolean>
    -isBusy: input<boolean>
    --
    +onRename(): void
    +onConfigure(): void
    +onFirmware(): void
    +onDelete(): void
  }

  class "GatewayRenameModalComponent" as RenameModal {
    --
    -open: input<boolean>
    -currentName: input<string>
    -busy: input<boolean>
    --
    +submit(event: Event, nextNameRaw: string): void
    +close(): void
  }

  class "CommandModalComponent" as CommandModal {
    --
    -open: input<boolean>
    -mode: input<CommandModalMode>
    -busy: input<boolean>
    -initialSendFrequencyMs: input<number | null>
    -initialStatus: input<CmdGatewayStatus | null>
    --
    +submitConfig(event: Event, frequencyRaw: string, statusRaw: string): void
    +submitFirmware(event: Event, version: string, downloadUrl: string): void
    +close(): void
  }

  package "Gateway Services" as Services {
    class "GatewayService" as GatewaySvc {
      --
      -listSignal: Signal<Gateway[]>
      -selectedGatewaySignal: Signal<Gateway | null>
      -loadingSignal: Signal<boolean>
      -gatewaysApi: GatewaysService (generated)
      --
      +getGateways(): Observable<Gateway[]>
      +getGatewayDetail(gatewayId: string): Observable<Gateway>
      +updateGatewayName(gatewayId: string, name: string): Observable<GatewayUpdateResult>
      +deleteGateway(gatewayId: string): Observable<string>
      +list(): Signal<Gateway[]>
      +selectedGateway(): Signal<Gateway | null>
      +isLoading(): Signal<boolean>
      -toGatewayStatus(status: unknown): GatewayStatus
      -toGateway(dto: GatewayResponseDto): Gateway
    }

    class "CommandService" as CommandSvc {
      --
      -commandsApi: CommandsService (generated)
      --
      +sendConfig(id: string, config: GatewayConfig): Observable<CommandStatusUpdate>
      +sendFirmware(id: string, firmware: GatewayFirmware): Observable<CommandStatusUpdate>
      +pollStatus(gwId: string, cmdId: string, intervalMs: number): Observable<CommandStatusUpdate>
      -toCommandStatus(status: string): CommandStatus
    }
  }

  ' Internal Relationships
  GatewayListPage --> GatewayCard
  GatewayListPage --> GatewaySvc
  GatewayDetailPage --> GatewaySvc
  GatewayDetailPage --> CommandSvc
  GatewayDetailPage --> RenameModal
  GatewayDetailPage --> CommandModal
  GatewayDetailPage --> GatewayActions
  
  ' External Dependencies Relationships
  GatewayDetailPage --> DeleteModal
  GatewayDetailPage --> AuthSvc
  GatewayDetailPage --> SensorSvc
  GatewayDetailPage --> ObfMeasureSvc
  GatewayDetailPage --> ValMeasureSvc
  GatewayDetailPage --> TelemetryTable
  
  GatewayCard --> StatusBadge
  RenameModal --> ModalLayer
  CommandModal --> ModalLayer
  DeleteModal --> ModalLayer
}

note top of GatewaySvc
  Maintains internal signals for list,
  selected gateway, and loading state.
  Exposes them as read-only Signal<T>
  via public getters. Normalizes status
  from API (handles uppercase, camelCase,
  paused/offline variants).
end note

note right of CommandSvc
  Sends config/firmware commands
  then polls status every 2s with
  5-minute timeout. Maps 304 to cache,
  404/503 to timeout. Filters out
  invalid fields from payload.
  Rejects commands with disallowed status.
end note

note bottom of GatewayDetailPage
  Most complex page in the application.
  Combines: gateway summary, rename,
  command sending (config + firmware),
  delete confirmation, sensor list,
  and live telemetry stream. 
  Relies on external core services for 
  impersonation checks and telemetry.
end note

@enduml