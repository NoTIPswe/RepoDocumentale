@startuml
title NOTIP Frontend - Shared Components

skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam defaultFontColor #000000
skinparam nodesep 8
skinparam ranksep 8
skinparam linetype ortho

package "Shared Components" <<Rectangle>> {
  
  class "SidebarComponent" as Sidebar {
    -- Inputs (Signals) --
    +isImpersonating: Signal<boolean>
    +username: Signal<string>
    +role: Signal<UserRole>
    -- Outputs --
    +logoutRequested: OutputEmitterRef<void>
    +impersonationStopRequested: OutputEmitterRef<void>
    +profileRequested: OutputEmitterRef<void>
    +passwordChangeRequested: OutputEmitterRef<void>
    --
    +menuItems(): MenuItem[]
    +emitLogout(): void
    +emitImpersonationStopRequested(): void
    +emitProfileRequested(): void
    +emitPasswordChangeRequested(): void
    -currentRole(): UserRole
  }

  class "ModalLayerComponent" as ModalLayer {
    -- Inputs (Signals) --
    +open: Signal<boolean>
    +closeOnBackdrop: Signal<boolean>
    -- Outputs --
    +backdropClosed: OutputEmitterRef<void>
    --
    +onHostClick(event: MouseEvent): void
  }

  class "MultiSelectDropdownComponent" as MultiSelect {
    -- Inputs (Signals) --
    +options: Signal<string[]>
    +selected: Signal<string[]>
    +placeholder: Signal<string>
    +searchPlaceholder: Signal<string>
    +noResultsLabel: Signal<string>
    +disabled: Signal<boolean>
    -- Outputs --
    +selectedChange: OutputEmitterRef<string[]>
    -- State (Signals) --
    +isOpen: WritableSignal<boolean>
    +searchTerm: WritableSignal<string>
    --
    +onDocumentClick(event: MouseEvent): void
    +onEscape(): void
    +toggleMenu(): void
    +updateSearch(value: string): void
    +toggleOption(value: string): void
    +isSelected(value: string): boolean
    +selectionLabel(): string
    +filteredOptions(): string[]
    -normalizedOptions(): string[]
    -closeMenu(): void
  }

  class "StatusBadgeComponent" as StatusBadge {
    -- Inputs (Signals) --
    +status: Signal<string>
    --
    +badgeClass(): string
  }

  class "DeleteConfirmModalComponent" as DeleteModal {
    -- Inputs (Signals) --
    +open: Signal<boolean>
    +title: Signal<string>
    +message: Signal<string>
    +busy: Signal<boolean>
    -- Outputs --
    +confirmed: OutputEmitterRef<void>
    +cancelled: OutputEmitterRef<void>
    --
    +onConfirm(): void
    +onCancel(): void
  }

  class "ProfileSectionComponent" as ProfileSection {
    -- Inputs (Signals) --
    +username: Signal<string> <<required>>
    +role: Signal<string> <<required>>
    +showProfileLink: Signal<boolean>
    -- Outputs --
    +profileRequested: OutputEmitterRef<void>
    +passwordChangeRequested: OutputEmitterRef<void>
    --
    +emitProfileRequested(event: Event): void
    +emitPasswordChangeRequested(event: Event): void
  }

  class "ImpersonationTagComponent" as ImpTag {
    --
    // Static component showing
    // "OBFUSCATED MODE" warning
  }

  class "LogoutButtonComponent" as LogoutBtn {
    -- Outputs --
    +clicked: OutputEmitterRef<void>
    --
    +onClick(): void
  }

  class "ImpersonationBannerComponent" as ImpBanner {
    -- Inputs (Signals) --
    +active: Signal<boolean>
    +impersonatedUserId: Signal<string | null>
    --
    // Defined in shared, but not used by Sidebar
  }

  class "PlaceholderPageComponent" as PlaceholderPage {
    -- Properties --
    +title: string
    --
    // Scaffold page for features in development
  }

  ' Usage relationships derived from imports
  Sidebar --> ImpTag
  Sidebar --> ProfileSection
  Sidebar --> LogoutBtn

  DeleteModal --> ModalLayer
}

note top of Sidebar
  Main navigation sidebar. Shows/hides
  menu items based on user role 
  (tenant_user, tenant_admin, system_admin).
  During impersonation: shows ImpersonationTag
  and "Exit impersonation" button.
end note

note right of ModalLayer
  Generic modal overlay with backdrop.
  Uses HTML <dialog> element.
  Listens to @HostListener clicks to detect
  when the dialog backdrop is clicked.
end note

note left of MultiSelect
  Reusable multi-select dropdown with
  integrated search. Opens/closes via
  document click and Escape key.
  Fully driven by Angular Signals.
end note

note bottom of StatusBadge
  Colored badge component mapping
  status strings to CSS classes:
  - is-good: online, ack
  - is-warn: paused, provisioning, queued
  - is-bad: offline, nack, expired, timeout, error
  - is-neutral: default
end note

@enduml