@startuml visualizzazione_configurazione_simulazione_sensore
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Utente del Simulatore" as sim_usr

rectangle "Simulatore Gateway" {
  usecase "UCS18.2 - Visualizzazione algoritmo generazione dati" as UCS18_2
  usecase "UCS18 - Visualizzazione configurazione simulazione sensore" as UCS18
  usecase "UCS18.1 - Visualizzazione range generazione dati" as UCS18_1
  usecase "UCS20 - Visualizzazione identificativo sensore" as UCS20
  usecase "UCS23 - Visualizzazione tipo sensore simulato" as UCS23
}

sim_usr -- UCS18

UCS18 ..> UCS20 : <<include>>
UCS18 ..> UCS23 : <<include>>
UCS18 ..> UCS18_1 : <<include>>
UCS18 ..> UCS18_2 : <<include>>

@enduml