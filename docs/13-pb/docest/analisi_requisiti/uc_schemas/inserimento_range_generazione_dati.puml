@startuml inserimento_range_generazione_dati
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Utente del Simulatore" as sim_usr

rectangle "Simulatore Gateway" {
  usecase "UCS16 - Inserimento range generazione dati" as UCS16
  usecase "UCS12 - Errore range invalido del sensore simulato" as UCS12
}

sim_usr -- UCS16

UCS12 ..> UCS16 : <<extend>>
note on link
  Extension Point: ErroreRangeInvalido
  Condition: I valori inseriti non sono validi
end note

@enduml