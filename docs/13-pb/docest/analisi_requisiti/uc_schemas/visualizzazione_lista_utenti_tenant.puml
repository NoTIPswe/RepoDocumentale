@startuml visualizzazione_lista_utenti_tenant
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Tenant Admin" as tenant_adm

rectangle "Sistema Cloud" {
  usecase "UC104 - Visualizzazione lista Utenti del Tenant" as UC104
  usecase "UC104.1.2 - Visualizzazione nome dell’Utente" as UC104_1_2
  usecase "UC104.1.1 - Visualizzazione ruolo dell’Utente" as UC104_1_1
  usecase "UC104.1 - Visualizzazione singolo Utente del Tenant" as UC104_1
  usecase "UC104.1.3 - Visualizzazione ultimo accesso dell’Utente" as UC104_1_3
  usecase "UC106 - Visualizzazione mail dell’Utente" as UC106
}

tenant_adm -- UC104

UC104 ..> UC104_1 : <<include>>
UC104_1 ..> UC104_1_1 : <<include>>
UC104_1 ..> UC104_1_2 : <<include>>
UC104_1 ..> UC106 : <<include>>
UC104_1 ..> UC104_1_3 : <<include>>

@enduml