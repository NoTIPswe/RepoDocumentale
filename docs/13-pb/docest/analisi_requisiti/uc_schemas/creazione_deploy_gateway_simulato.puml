@startuml creazione_deploy_gateway_simulato
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Utente del Simulatore" as sim_usr

rectangle "Simulatore Gateway" {
  usecase "UCS4 - Creazione e Deploy di un Gateway simulato" as UCS4
  usecase "UCS4.1 - Inserimento dati configurazione simulazione Gateway" as UCS4_1
  usecase "UCS4.1.2 - Sel Modello Gateway" as UCS4_1_2
  usecase "UCS4.1.1 - Sel Sn Gateway" as UCS4_1_1
  usecase "UCS4.1.3 - Sel Versione Sw Gateway" as UCS4_1_3
  usecase "UCS11 - Errore Deploy Gateway simulato" as UCS11
}

sim_usr -- UCS4

UCS4 ..> UCS4_1 : <<include>>
UCS4_1 ..> UCS4_1_1 : <<include>>
UCS4_1 ..> UCS4_1_2 : <<include>>
UCS4_1 ..> UCS4_1_3 : <<include>>
UCS11 ..> UCS4 : <<extend>>
note on link
  Extension Point: ErroreDeploy
  Condition: Errore di sistema nella creazione delle istanze
end note

@enduml