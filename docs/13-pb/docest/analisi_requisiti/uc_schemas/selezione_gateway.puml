@startuml selezione_gateway
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Amministratore di Sistema" as sys_adm
actor "Tenant Admin" as tenant_adm

rectangle "Sistema Cloud" {
  usecase "UC78 - Selezione Gateway" as UC78
}

sys_adm -- UC78
tenant_adm -- UC78


@enduml