@startuml modifica_nome_gateway
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Tenant Admin" as tenant_adm

rectangle "Sistema Cloud" {
  usecase "UC63 - Modifica nome Gateway" as UC63
  usecase "UC30 - Errore nome Gateway duplicato" as UC30
}

tenant_adm -- UC63

UC30 ..> UC63 : <<extend>>
note on link
  Extension Point: NomeDuplicato
  Condition: Il nome inserito è già assegnato ad un altro Gateway nel Tenant
end note

@enduml