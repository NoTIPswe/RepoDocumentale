@startuml visualizzazione_stato_tenant
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Amministratore di Sistema" as sys_adm

rectangle "Sistema Cloud" {
  usecase "UC87 - Visualizzazione stato Tenant attivo" as UC87
  usecase "UC88 - Visualizzazione stato Tenant sospeso" as UC88
  usecase "UC111 - Visualizzazione stato Tenant" as UC111
}

sys_adm -- UC111

UC111 <|-- UC87
UC111 <|-- UC88

@enduml