@startuml modifica_frequenza_invio_gateway
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Tenant Admin" as tenant_adm
actor "Provisioned Gateway" as p_gway

rectangle "Sistema Cloud" {
  usecase "UC54 - Modifica frequenza invio dati Gateway specifico" as UC54
  usecase "UC48 - Inserimento valore numerico" as UC48
}

tenant_adm -- UC54
p_gway -- UC54

UC54 ..> UC48 : <<include>>

@enduml