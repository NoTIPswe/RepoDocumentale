@startuml visualizzazione_costi_stimati
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
}

actor "Tenant Admin" as tenant_adm

rectangle "Sistema Cloud" {
  usecase "UC90.2 - Visualizzazione costi stimati per banda" as UC90_2
  usecase "UC90 - Visualizzazione costi stimati" as UC90
  usecase "UC90.1 - Visualizzazione costi stimati per storage" as UC90_1
  usecase "UC78 - Selezione Gateway" as UC78
}

tenant_adm -- UC90

UC90 ..> UC78 : <<include>>
UC90 ..> UC90_1 : <<include>>
UC90 ..> UC90_2 : <<include>>

@enduml